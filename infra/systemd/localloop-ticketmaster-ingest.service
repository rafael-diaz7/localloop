[Unit]
Description=LocalLoop Ticketmaster Discovery ingestion
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
User=goose
Group=goose
WorkingDirectory=/home/goose/projects/localloop
EnvironmentFile=/home/goose/projects/localloop/.env
Environment=PATH=/home/goose/.nvm/versions/node/v24.16.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/home/goose/.nvm/versions/node/v24.16.0/bin/pnpm ingest:ticketmaster
